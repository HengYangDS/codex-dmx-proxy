# Codex DMX Proxy configuration example
#
# Every setting has a built-in default. Most installations should use install.py
# arguments and leave the generated service definition unchanged.

# Verified third-party upstream base URL.
DMX_UPSTREAM=https://www.dmxapi.cn

# Loopback listener port.
DMX_PROXY_PORT=8791

# Maximum concurrent /responses requests.
DMX_RESPONSES_MAX_CONCURRENCY=64

# Full-request byte budget for each pair-safe fallback after an explicit
# upstream HTTP 400 `response_failed`. This is intentionally conservative.
DMX_RESPONSE_FAILED_COMPACTION_BUDGET=524288

# Maximum number of pair-safe fallback stages before the one dialogue-only
# recovery attempt. Set to 0 to skip pair-safe compaction, not the final
# dialogue-only recovery. The default is deliberately conservative.
DMX_RESPONSE_FAILED_MAX_STAGES=3

# Maximum bytes in each structured proxy log segment and the number of rotated
# segments retained. The proxy never logs request bodies, credentials, headers,
# prompts, or raw upstream payloads. Values outside their supported bounds are
# clamped by the runtime; use install.py arguments to persist a new service value.
DMX_PROXY_LOG_MAX_BYTES=4194304
DMX_PROXY_LOG_BACKUP_COUNT=3

# Maximum bytes in each structured watchdog log segment and the number of rotated
# segments retained. Native service stdout and stderr are discarded deliberately;
# use this bounded log for watchdog lifecycle evidence.
DMX_WATCHDOG_LOG_MAX_BYTES=524288
DMX_WATCHDOG_LOG_BACKUP_COUNT=2

# Watchdog TCP health-check interval, in seconds.
DMX_WATCHDOG_INTERVAL=15

# Recommended override method:
#   python3 install.py --port 8801 --upstream https://your.responses.endpoint
