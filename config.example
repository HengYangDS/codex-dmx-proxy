# Codex DMX Proxy configuration example
#
# Every setting has a built-in default. Most installations should use install.py
# arguments and leave the generated service definition unchanged.

# Verified third-party upstream base URL.
DMX_UPSTREAM=https://www.dmxapi.cn

# Loopback listener port.
DMX_PROXY_PORT=8791

# Maximum concurrent /responses requests.
DMX_RESPONSES_MAX_CONCURRENCY=64

# Full-request byte budget for the one pair-safe fallback after an explicit
# upstream HTTP 400 `response_failed`. This is intentionally conservative.
DMX_RESPONSE_FAILED_COMPACTION_BUDGET=524288

# Watchdog TCP health-check interval, in seconds.
DMX_WATCHDOG_INTERVAL=15

# Recommended override method:
#   python3 install.py --port 8801 --upstream https://your.responses.endpoint
