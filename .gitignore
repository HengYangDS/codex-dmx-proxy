# Python
__pycache__/
*.pyc
*.pyo
.ruff_cache/

# Logs / runtime artifacts (never commit)
#
# Current proxy and watchdog logs are structured and secret-safe by contract.
# Historical files and unrelated runtime artifacts are still untrusted local data,
# so neither logs nor rejected-payload captures belong in source control.
*.log
log/
body-*.json

# Local config backups (may contain API keys)
config.toml
*.bak-*

# OS cruft
.DS_Store
Thumbs.db

# Local linked worktrees
.worktrees/
